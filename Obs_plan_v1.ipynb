import numpy as np
import matplotlib.pyplot as plt
import matplotlib.dates as mdates
import warnings
from astropy import units as u
from astropy.time import Time
from astropy.coordinates import EarthLocation, AltAz, SkyCoord, get_sun
from astroplan import Observer, FixedTarget
from astropy.utils.exceptions import AstropyWarning
from matplotlib.patches import Patch
from matplotlib.lines import Line2D

# 屏蔽无关警告 / Suppress warnings
warnings.simplefilter('ignore', category=AstropyWarning)

def plot_variable_star_plan(obs_location, target_info, obs_date, period_days, t0_jd):
    """
    变星观测规划主函数 / Main function for variable star observation planning
    """
    
    # 1. 环境初始化 / Initialization
    location = EarthLocation(lon=obs_location['lon'] * u.deg, 
                             lat=obs_location['lat'] * u.deg, 
                             height=obs_location['height'] * u.m)
    obs_site = Observer(location=location, name=obs_location['name'], timezone='Asia/Shanghai')

    target_coord = SkyCoord(target_info['ra'], target_info['dec'], unit=(u.hourangle, u.deg))
    target = FixedTarget(coord=target_coord, name=target_info['name'])

    # 2. 时间序列 (17:00 到 次日 07:00) / Time Series (17:00 to 07:00 next day)
    start_time_local = Time(f"{obs_date} 17:00:00")
    start_time_utc = start_time_local - 8 * u.hour
    time_grid = start_time_utc + np.linspace(0, 14, 2000) * u.hour
    
    beijing_times = (time_grid + 8 * u.hour).datetime
    jds = time_grid.jd

    # 3. 计算高度和相位 / Altitude and Phase Calculation
    altaz_frame = obs_site.altaz(time_grid, target)
    target_alt = altaz_frame.alt.value
    sun_alt = obs_site.altaz(time_grid, get_sun(time_grid)).alt.value
    
    # 相位计算并处理跳变连线 / Phase calculation and break jump lines
    raw_phases = ((time_grid.jd - t0_jd) / period_days) % 1.0
    phases_plot = raw_phases.copy()
    jump_idx = np.where(np.abs(np.diff(raw_phases)) > 0.5)[0]
    for idx in jump_idx:
        phases_plot[idx] = np.nan 

    # 观测窗口判定 / Observation window criteria
    is_observable = (target_alt > 30) & (sun_alt < -12)

    # 4. 绘图 / Plotting
    plt.rcParams['font.sans-serif'] = ['Arial']
    fig = plt.figure(figsize=(14, 8.5), dpi=150)
    ax1 = fig.add_axes([0.1, 0.22, 0.78, 0.63]) 
    ax1.set_facecolor('white')

    # A. 绘制背景区域 / Background fills (zorder=1,2)
    ax1.fill_between(beijing_times, 0, 90, where=(sun_alt < 0) & (sun_alt >= -12), 
                     color='#eeeeee', alpha=0.8, label='Nautical Twilight', zorder=1)
    ax1.fill_between(beijing_times, 0, 90, where=(sun_alt < -12) & (sun_alt >= -18), 
                     color='#dbdbdb', alpha=0.8, label='Astronomical Twilight', zorder=1)
    ax1.fill_between(beijing_times, 0, 90, where=(sun_alt < -18), 
                     color='#c9c9c9', alpha=0.8, label='Astronomical Night', zorder=1)
    ax1.fill_between(beijing_times, 0, target_alt, where=is_observable, 
                     color='#c8e6c9', alpha=0.9, label='Observable Window', zorder=2)

    # B. 绘制网格线 (关键！zorder=5 确保在绿色区域上方可见) / Grid lines (zorder=5)
    ax1.grid(True, which='major', axis='both', color='black', linestyle=':', linewidth=0.8, alpha=0.3, zorder=5)

    # C. 绘制曲线 / Curves (zorder=10)
    line_alt, = ax1.plot(beijing_times, target_alt, color='green', lw=2.5, label='Target Altitude', zorder=10)
    line_limit = ax1.axhline(30, color='yellow', linestyle='-.', lw=1.5, alpha=0.9, zorder=10)
    
    ax2 = ax1.twinx()
    line_phase, = ax2.plot(beijing_times, phases_plot, color='#e65100', linestyle='--', lw=1.5, alpha=0.9, label='Phase', zorder=10)
    
    # 相位引导线 / Phase reference lines (zorder=5)
    phase_targets = {0.25: '#3498db', 0.50: '#e74c3c', 0.75: '#2ecc71'}
    for p_val, p_color in phase_targets.items():
        ax2.axhline(p_val, color=p_color, linestyle=':', lw=1.5, alpha=0.6, zorder=5)
        idx = np.where(np.abs(raw_phases - p_val) < 0.001)[0]
        if len(idx) > 0:
            ax2.scatter(beijing_times[idx], [p_val]*len(idx), color=p_color, s=35, edgecolors='white', zorder=11)

    ax2.set_ylim(0, 1.05)
    ax2.set_yticks([0, 0.25, 0.5, 0.75, 1.0])
    ax2.set_ylabel('Variable Phase (0.0 - 1.0)', fontsize=12, fontweight='bold', color='#e65100', labelpad=10)

    # D. 坐标轴设置 / Axis settings
    # 顶部 JD 轴
    ax_jd = ax1.twiny()
    ax_jd.set_xlim(ax1.get_xlim())
    jd_indices = np.linspace(0, len(jds)-1, 7, dtype=int)
    ax_jd.set_xticks(mdates.date2num(beijing_times[jd_indices]))
    ax_jd.set_xticklabels([f"{jds[i]:.3f}" for i in jd_indices])
    ax_jd.set_xlabel('Julian Date (JD)', fontsize=11, fontweight='bold', labelpad=12)

    # 底部北京时间轴
    ax1.set_xlabel(f'Local Time (Beijing, UTC+8, {obs_date})', fontsize=11, fontweight='bold', labelpad=8)
    ax1.xaxis.set_major_formatter(mdates.DateFormatter('%H:%M'))
    ax1.xaxis.set_major_locator(mdates.HourLocator(interval=2))
    
    # 底部 UTC 时间轴 (偏移 8 小时)
    ax_utc = ax1.twiny()
    ax_utc.xaxis.set_ticks_position('bottom')
    ax_utc.xaxis.set_label_position('bottom')
    ax_utc.spines['bottom'].set_position(('outward', 45))
    bjt_min, bjt_max = ax1.get_xlim()
    ax_utc.set_xlim(bjt_min - 8/24.0, bjt_max - 8/24.0) 
    ax_utc.xaxis.set_major_formatter(mdates.DateFormatter('%H:%M'))
    ax_utc.xaxis.set_major_locator(mdates.HourLocator(interval=2))
    ax_utc.set_xlabel('UTC Time (UTC+0)', fontsize=11, fontweight='bold')

    # E. 边框与图例 / Spines and Legend
    for ax in [ax1, ax2, ax_jd, ax_utc]:
        for spine in ax.spines.values():
            spine.set_edgecolor('black')
            spine.set_linewidth(1.5)
        ax.tick_params(direction='in', length=5, width=1.5)

    legend_elements = [
        line_alt, line_phase,
        Line2D([0], [0], color='yellow', linestyle='-.', lw=1.5, label='Altitude Limit (30°)'),
        Patch(facecolor='#c8e6c9', label='Observable Window'),
        Patch(facecolor='#c9c9c9', label='Astronomical Night'),
        Patch(facecolor='#eeeeee', label='Twilight')
    ]
    leg = ax2.legend(handles=legend_elements, loc='upper left', frameon=True, fontsize=10)
    leg.get_frame().set_facecolor('white')
    leg.get_frame().set_alpha(1.0) 
    leg.set_zorder(100)

    ax1.set_ylim(0, 90)
    ax1.set_ylabel('Altitude (Degrees)', fontsize=12, fontweight='bold', color='#000080', labelpad=10)
    plt.title(f"{target_info['name']} Planning | {obs_location['name']}\nRA: {target_info['ra']}, Dec: {target_info['dec']}", 
              fontsize=14, fontweight='bold', pad=45)

    # 5. 保存 PDF / Save to PDF
    loc_clean = obs_location['name'].replace(' ', '_')
    target_clean = target_info['name'].replace(' ', '_')
    pdf_name = f"{target_clean}_{loc_clean}_{obs_date.replace('-', '')}.pdf"
    plt.savefig(pdf_name, format='pdf', bbox_inches='tight')

    # --- 关键：报告输出部分 / Report Output ---
    print("\n" + "="*50)
    print(f" 观测规划报告 / OBSERVATION REPORT: {target_info['name']}")
    print("="*50)
    print(f"地点 / Location: {obs_location['name']}")
    print(f"坐标 / Coordinates: RA {target_info['ra']}, Dec {target_info['dec']}")
    print(f"日期 / Date: {obs_date}")
    print("-" * 50)
    
    if np.any(is_observable):
        # 提取观测窗口数据
        obs_times_bjt = beijing_times[is_observable]
        obs_times_utc = (time_grid[is_observable]).datetime
        obs_jds = jds[is_observable]
        obs_phases = raw_phases[is_observable]
        
        print(f"北京时间观测窗口 / Observation BJT Window: {obs_times_bjt[0].strftime('%H:%M')} - {obs_times_bjt[-1].strftime('%H:%M')}")
        print(f"UTC 时间观测窗口 / Observation UTC Window: {obs_times_utc[0].strftime('%H:%M')} - {obs_times_utc[-1].strftime('%H:%M')}")
        # print(f"儒略日范围 / JD Range:  {obs_jds[0]:.4f} - {obs_jds[-1]:.4f}")
        print(f"观测相位区间 / Phase Range: {obs_phases[0]:.3f} - {obs_phases[-1]:.3f}")
        print("-" * 50)
        print(f"观测窗口总时长 / Duration:  {(obs_jds[-1] - obs_jds[0])*24:.2f} 小时/hours")
    else:
        print("警告: 该日期内没有满足条件的观测窗口 (高度>30且天黑)。")
        print("WARNING: No observable window found for this date.")
    
    print(f"PDF 文件已生成 / PDF Generated: {pdf_name}")
    print("="*50 + "\n")

    plt.show()

# --- 用户配置区 / Config Area ---
my_location = {'name': 'Lijiang', 'lon': 100.03, 'lat': 26.69, 'height': 3200}
my_target = {'name': 'bet Per', 'ra': '03:08:10.1324535', 'dec': '+40:57:20.328013'}
my_date = "2026-01-1"
my_period = 2.867343 
my_t0 = 2457675.72

# 执行 / Execute
plot_variable_star_plan(my_location, my_target, my_date, my_period, my_t0)
